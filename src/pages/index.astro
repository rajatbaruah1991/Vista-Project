---
import { Image } from 'astro:assets';
import slider1 from '../assets/slider-1.jpg';
import slider2 from '../assets/slider-2.jpg';
import slider3 from '../assets/slider-3.jpg';
import '../styles/global.css';
import MainLayout from '../layouts/MainLayout.astro';

// Gallery images for the auto-scrolling slider
const galleryImages = import.meta.glob('../assets/gallery/*.webp', { eager: true });
const galleryAssets = Object.values(galleryImages).map((img: any) => img.default);
---

<MainLayout title="Home | Vista Educare" activePage="home">

  <!-- ═══════════ HERO IMAGE SLIDER ═══════════ -->
  <section class="relative h-screen overflow-hidden">
    <div class="slider-container h-full" id="heroSlider">
      <div class="slider-track h-full" id="sliderTrack">
        <!-- Slide 1 -->
        <div class="slider-slide h-full">
          <Image src={slider1} alt="Students collaborating" class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
          <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/60 to-transparent"></div>
          <div class="absolute inset-0 flex items-center">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
              <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/90 text-sm font-medium mb-6">
                  <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-green-400"></span>
                  </span>
                  Vista Educare Welcomes You
                </div>
                <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black text-white leading-[0.95] mb-6" style="font-size: clamp(2.25rem, 5vw + 1rem, 4.5rem);">
                  Make Your Future
                  <span class="block mt-2"><span class="text-red">Digital</span> <span class="text-indigo-light">With Us</span></span>
                </h1>
                <p class="text-lg text-white/50 mb-10 max-w-lg leading-relaxed">Bridging knowledge and opportunities in the tech-driven world. Industry-certified courses with expert mentorship and placement support.</p>
                <div class="flex flex-wrap gap-4">
                  <a href="/courses" class="px-8 py-4 btn-red font-bold rounded-2xl text-lg inline-flex items-center gap-2">Search Courses <span class="material-symbols-rounded">search</span></a>
                  <a href="/contact" class="px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/15 text-white font-semibold rounded-2xl hover:bg-white/20 transition-all text-lg">Enroll Us</a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- Slide 2 -->
        <div class="slider-slide h-full">
          <Image src={slider2} alt="Classroom session" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/60 to-transparent"></div>
          <div class="absolute inset-0 flex items-center">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
              <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/90 text-sm font-medium mb-6">
                  <span class="material-symbols-rounded text-yellow-400 text-sm">workspace_premium</span>
                  Certified Institution · Trade Mark Act 1999
                </div>
                <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[0.95] mb-6">
                  Enhance Your Skills
                  <span class="block mt-2"><span class="text-red">With Best</span> <span class="text-indigo-light">Courses</span></span>
                </h1>
                <p class="text-lg text-white/50 mb-10 max-w-lg leading-relaxed">From Power BI to Web Development, Graphic Design to Data Science — master the skills that industry demands.</p>
                <div class="flex flex-wrap gap-4">
                  <a href="/courses" class="px-8 py-4 btn-navy font-bold rounded-2xl text-lg inline-flex items-center gap-2">View Courses <span class="material-symbols-rounded">school</span></a>
                  <a href="/contact" class="px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/15 text-white font-semibold rounded-2xl hover:bg-white/20 transition-all text-lg">Contact Us</a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- Slide 3 -->
        <div class="slider-slide h-full">
          <Image src={slider3} alt="Education campus" class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/60 to-transparent"></div>
          <div class="absolute inset-0 flex items-center">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
              <div class="max-w-2xl">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/90 text-sm font-medium mb-6">
                  <span class="material-symbols-rounded text-green-400 text-sm">storefront</span>
                  Franchise Opportunities
                </div>
                <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white leading-[0.95] mb-6">
                  Own a
                  <span class="block mt-2"><span class="text-red">Vista</span> <span class="text-indigo-light">Educare</span> Center</span>
                </h1>
                <p class="text-lg text-white/50 mb-10 max-w-lg leading-relaxed">Start your own education center with our proven franchise model. 18 franchises and growing. Join the Vista Educare family.</p>
                <div class="flex flex-wrap gap-4">
                  <a href="/franchise" class="px-8 py-4 btn-red font-bold rounded-2xl text-lg inline-flex items-center gap-2">Start Franchise <span class="material-symbols-rounded">trending_up</span></a>
                  <a href="/franchise" class="px-8 py-4 bg-white/10 backdrop-blur-sm border border-white/15 text-white font-semibold rounded-2xl hover:bg-white/20 transition-all text-lg">Know More</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Slider controls -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-3 z-20">
        <button class="slider-dot active" data-slide="0" aria-label="Slide 1"></button>
        <button class="slider-dot" data-slide="1" aria-label="Slide 2"></button>
        <button class="slider-dot" data-slide="2" aria-label="Slide 3"></button>
      </div>

      <!-- Arrow buttons -->
      <button id="prevSlide" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full glass flex items-center justify-center text-white/80 hover:text-white hover:bg-white/15 transition-all" aria-label="Previous">
        <span class="material-symbols-rounded">chevron_left</span>
      </button>
      <button id="nextSlide" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-12 h-12 rounded-full glass flex items-center justify-center text-white/80 hover:text-white hover:bg-white/15 transition-all" aria-label="Next">
        <span class="material-symbols-rounded">chevron_right</span>
      </button>
    </div>
  </section>

  <!-- ═══════════ STATS BAR ═══════════ -->
  <section class="py-6 bg-white border-b border-gray-100 relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="flex items-center gap-4 justify-center">
          <div class="w-12 h-12 rounded-xl bg-red/10 flex items-center justify-center">
            <span class="material-symbols-rounded text-red text-2xl">school</span>
          </div>
          <div>
            <div class="text-2xl font-black text-dark counter" data-target="7123" data-suffix="+">0</div>
            <div class="text-xs text-gray-600 font-semibold uppercase tracking-wider">Students</div>
          </div>
        </div>
        <div class="flex items-center gap-4 justify-center">
          <div class="w-12 h-12 rounded-xl bg-navy/10 flex items-center justify-center">
            <span class="material-symbols-rounded text-navy text-2xl">groups</span>
          </div>
          <div>
            <div class="text-2xl font-black text-dark counter" data-target="69" data-suffix="">0</div>
            <div class="text-xs text-gray-600 font-semibold uppercase tracking-wider">Faculties</div>
          </div>
        </div>
        <div class="flex items-center gap-4 justify-center">
          <div class="w-12 h-12 rounded-xl bg-red/10 flex items-center justify-center">
            <span class="material-symbols-rounded text-red text-2xl">apartment</span>
          </div>
          <div>
            <div class="text-2xl font-black text-dark counter" data-target="18" data-suffix="">0</div>
            <div class="text-xs text-gray-600 font-semibold uppercase tracking-wider">Franchises</div>
          </div>
        </div>
        <div class="flex items-center gap-4 justify-center">
          <div class="w-12 h-12 rounded-xl bg-navy/10 flex items-center justify-center">
            <span class="material-symbols-rounded text-navy text-2xl">menu_book</span>
          </div>
          <div>
            <div class="text-2xl font-black text-dark counter" data-target="71" data-suffix="">0</div>
            <div class="text-xs text-gray-600 font-semibold uppercase tracking-wider">Courses</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURED COURSES ═══════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red/[0.06] text-red text-xs font-bold uppercase tracking-[0.2em] mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-red"></span>Enroll With Our Courses
        </span>
        <h2 class="text-4xl sm:text-5xl font-black text-dark mb-4">Featured <span class="text-navy">Courses</span></h2>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg">From fundamentals to advanced specializations — choose from 71+ industry-relevant programs.</p>
      </div>

      <!-- Mobile Carousel / Desktop Grid -->
      <div class="relative">
        <div id="coursesTrack" class="flex sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-8 overflow-x-auto sm:overflow-visible snap-x snap-mandatory scrollbar-hide pb-4 sm:pb-0 -mx-4 px-4 sm:mx-0 sm:px-0">
          {[
            { icon: 'bar_chart', name: 'Power BI', desc: 'Master data visualization, dashboard creation, DAX formulas & business intelligence reporting.', dur: '3 Months', level: 'Beginner–Advanced', color: 'red' },
            { icon: 'code', name: 'Web Development', desc: 'Learn HTML, CSS, JavaScript, React & Node.js. Build full-stack web applications.', dur: '6 Months', level: 'Beginner–Advanced', color: 'navy' },
            { icon: 'palette', name: 'Graphic Design', desc: 'Master Photoshop, Illustrator, InDesign & Figma. Create stunning visual content.', dur: '4 Months', level: 'Beginner', color: 'red' },
            { icon: 'description', name: 'DCA', desc: 'Diploma in Computer Applications covering MS Office, internet basics, programming & tally.', dur: '6 Months', level: 'Beginner', color: 'navy' },
            { icon: 'campaign', name: 'Digital Marketing', desc: 'SEO, Social Media, Google Ads & Analytics. Drive traffic and grow businesses online.', dur: '4 Months', level: 'Beginner–Advanced', color: 'red' },
            { icon: 'calculate', name: 'Tally & Accounting', desc: 'Tally Prime, GST, accounting fundamentals & financial statement preparation.', dur: '3 Months', level: 'Beginner', color: 'navy' },
          ].map((c, i) => (
            <div class="card-premium reveal group rounded-3xl overflow-hidden w-[85vw] max-w-full sm:w-auto flex-shrink-0 sm:flex-shrink snap-center flex flex-col" style={`transition-delay: ${i * 0.08}s`}>
              <div class={`h-1.5 bg-gradient-to-r flex-shrink-0 ${c.color === 'red' ? 'from-red to-red-dark' : 'from-navy to-indigo'}`}></div>
              <div class="p-8 flex flex-col flex-1">
                <div class={`w-14 h-14 rounded-2xl flex flex-shrink-0 items-center justify-center mb-6 transition-all duration-500 ${c.color === 'red' ? 'bg-red/10 group-hover:bg-red group-hover:shadow-lg group-hover:shadow-red/30' : 'bg-navy/10 group-hover:bg-navy group-hover:shadow-lg group-hover:shadow-navy/30'}`}>
                  <span class={`material-symbols-rounded text-2xl transition-colors duration-500 ${c.color === 'red' ? 'text-red group-hover:text-white' : 'text-navy group-hover:text-white'}`}>{c.icon}</span>
                </div>
                <h3 class="text-xl font-extrabold text-dark mb-3">{c.name}</h3>
                <p class="text-gray-400 text-sm mb-6 leading-relaxed flex-1">{c.desc}</p>
                <div class="flex flex-shrink-0 items-center justify-between text-xs text-gray-300 pt-4 border-t border-gray-100">
                  <span class="flex items-center gap-1.5 font-medium"><span class="material-symbols-rounded text-sm">schedule</span>{c.dur}</span>
                  <span class="flex items-center gap-1.5 font-medium"><span class="material-symbols-rounded text-sm">signal_cellular_alt</span>{c.level}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        <!-- Mobile carousel dots -->
        <div class="flex sm:hidden justify-center gap-1 mt-6 flex-wrap">
          {[0,1,2,3,4,5].map((idx) => (
             <button class="course-dot w-10 h-10 flex items-center justify-center" data-index={idx} aria-label={`Course ${idx+1}`}>
               <span class={`block w-2.5 h-2.5 rounded-full transition-all ${idx === 0 ? 'bg-navy' : 'bg-navy/30'}`}></span>
             </button>
          ))}
        </div>
      </div>

      <div class="text-center mt-14 reveal">
        <a href="/courses" class="inline-flex items-center gap-2 px-10 py-4 btn-red font-bold rounded-2xl text-lg">View All Courses <span class="material-symbols-rounded">arrow_forward</span></a>
      </div>
    </div>
  </section>

  <!-- ═══════════ GALLERY SLIDER ═══════════ -->
  {galleryAssets.length > 0 && (
  <section class="py-16 bg-light overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-10">
      <div class="flex items-center justify-between reveal">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red/[0.06] text-red text-xs font-bold uppercase tracking-[0.2em] mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-red"></span>Our Gallery
          </span>
          <h2 class="text-3xl sm:text-4xl font-black text-dark">Life at <span style="color: #ff0000;">Vista</span> <span style="color: #042dfc;">Educare</span></h2>
        </div>
        <a href="/gallery" class="hidden sm:inline-flex items-center gap-2 px-6 py-3 btn-navy font-bold rounded-2xl text-sm">View All <span class="material-symbols-rounded text-sm">arrow_forward</span></a>
      </div>
    </div>

    <!-- Auto-scrolling track -->
    <div class="gallery-scroll-container relative overflow-hidden">
      <div class="gallery-scroll-track flex gap-4" id="galleryScrollTrack">
        {/* Render images twice for seamless loop */}
        {[...galleryAssets, ...galleryAssets].map((img, i) => (
          <div class="gallery-scroll-item flex-shrink-0 w-64 sm:w-72 md:w-80 h-48 sm:h-56 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl hover:shadow-navy/15 transition-shadow duration-300 group cursor-pointer relative" data-gallery-src={img.src}>
            <Image
              src={img}
              alt={`Gallery ${(i % galleryAssets.length) + 1}`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-dark/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white scale-0 group-hover:scale-100 transition-transform duration-500">
                <span class="material-symbols-rounded">zoom_in</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-8 sm:hidden reveal">
      <a href="/gallery" class="inline-flex items-center gap-2 px-8 py-3 btn-navy font-bold rounded-2xl text-sm">View Gallery <span class="material-symbols-rounded text-sm">arrow_forward</span></a>
    </div>
  </section>
  )}

  <!-- ═══════════ ABOUT SECTION ═══════════ -->
  <section class="py-24 bg-light mesh-gradient">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-navy/[0.06] text-navy text-xs font-bold uppercase tracking-[0.2em] mb-6">
            <span class="w-1.5 h-1.5 rounded-full bg-navy"></span>About Us
          </span>
          <h2 class="text-4xl sm:text-5xl font-black text-dark mb-6 leading-tight">Bridging Knowledge &<br/>Opportunities in the<br/><span class="text-red">Tech-Driven World</span></h2>
          <p class="text-gray-400 leading-relaxed mb-8">Vista Educare is one such institute which is providing the best computer training to students from rural areas. Since 2014, Vista Educare has trained over 7,123+ students and is empowered by BIS Solution.</p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-red/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-rounded text-red text-xl">gavel</span>
              </div>
              <div>
                <h3 class="font-bold text-dark text-base">Trade Mark Act 1999</h3>
                <p class="text-gray-400 text-sm">Officially registered and protected under Indian trademark law.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-navy/10 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-rounded text-navy text-xl">verified</span>
              </div>
              <div>
                <h3 class="font-bold text-dark text-base">Certified Institution</h3>
                <p class="text-gray-400 text-sm">Industry-recognized certifications accepted by top employers nationwide.</p>
              </div>
            </div>
          </div>

          <a href="/about" class="inline-flex items-center gap-2 px-8 py-4 btn-navy font-bold rounded-2xl text-lg">Know More <span class="material-symbols-rounded">arrow_forward</span></a>
        </div>

        <div class="reveal relative" style="transition-delay: 0.2s;">
          <div class="rounded-3xl overflow-hidden shadow-2xl shadow-navy/10">
            <img src="/images/home-about.webp" alt="Vista Educare Students" class="w-full h-[400px] object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-6 -left-6 glass-light rounded-2xl p-5 shadow-xl">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-red to-red-dark flex items-center justify-center shadow-lg shadow-red/20">
                <span class="material-symbols-rounded text-white text-xl">emoji_events</span>
              </div>
              <div>
                <div class="text-2xl font-black text-dark">Since 2014</div>
                <div class="text-gray-400 text-xs font-semibold">Empowering Students</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ WHY CHOOSE US ═══════════ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <h2 class="text-4xl sm:text-5xl font-black text-dark mb-4">Why Choose <span class="text-red">Vista</span> <span class="text-navy">Educare</span></h2>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg">We don't just teach computers — we build futures. Our holistic approach ensures every student is market-ready.</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        <div class="card-premium reveal group p-8 rounded-3xl text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-red to-red-dark flex items-center justify-center mb-6 shadow-lg shadow-red/20 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-rounded text-white text-3xl">trending_up</span>
          </div>
          <h3 class="text-lg font-extrabold text-dark mb-3">Trending Courses</h3>
          <p class="text-gray-400 text-sm leading-relaxed">We offer cutting-edge courses in Computer, IT, Design, Marketing & more. Stay ahead with industry-relevant skills and modern curriculum.</p>
        </div>
        <div class="card-premium reveal group p-8 rounded-3xl text-center" style="transition-delay:0.1s">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-navy to-navy-dark flex items-center justify-center mb-6 shadow-lg shadow-navy/20 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-rounded text-white text-3xl">groups</span>
          </div>
          <h3 class="text-lg font-extrabold text-dark mb-3">Expert Team</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Our 69 expert faculty members bring years of industry experience. Personalized mentorship to help you succeed in your career goals.</p>
        </div>
        <div class="card-premium reveal group p-8 rounded-3xl text-center" style="transition-delay:0.2s">
          <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-red to-red-dark flex items-center justify-center mb-6 shadow-lg shadow-red/20 group-hover:scale-110 transition-transform duration-500">
            <span class="material-symbols-rounded text-white text-3xl">verified_user</span>
          </div>
          <h3 class="text-lg font-extrabold text-dark mb-3">Discipline</h3>
          <p class="text-gray-400 text-sm leading-relaxed">At Vista Educare, we maintain a disciplined learning environment. We inspire students to achieve their full potential every day.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TESTIMONIALS ═══════════ -->
  <section class="py-24 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-navy/[0.06] text-navy text-xs font-bold uppercase tracking-[0.2em] mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-navy"></span>Reviews
        </span>
        <h2 class="text-4xl sm:text-5xl font-black text-dark mb-4">Students <span class="text-red">Testimonial</span></h2>
      </div>

      <!-- Mobile Carousel / Desktop Grid -->
      <div class="relative">
        <div id="testimonialTrack" class="flex md:grid md:grid-cols-3 gap-8 overflow-x-auto md:overflow-visible snap-x snap-mandatory scrollbar-hide pb-4 md:pb-0 -mx-4 px-4 md:mx-0 md:px-0">
          {[
            { name: 'Swati Parihar', initials: 'SP', quote: '"Vista Educare gave me practical knowledge that helped me land my first job. The faculty are incredibly supportive and the course curriculum is industry-relevant."' },
            { name: 'Vikram Sinha', initials: 'VS', quote: '"I completed my computer course from Vista Educare and it completely transformed my career. The hands-on training approach is what sets them apart."' },
            { name: 'Kavita Suthar', initials: 'KS', quote: '"Amazing institute with dedicated faculty. Vista Educare helped me gain confidence and skills that I needed to grow in the IT industry."' },
          ].map((t, i) => (
            <div class="card-premium reveal p-8 rounded-3xl relative w-[85vw] max-w-full md:w-auto snap-center flex-shrink-0 md:flex-shrink flex flex-col h-auto" style={`transition-delay: ${i * 0.1}s`}>
              <div class="absolute top-6 right-8 text-7xl font-black text-navy/[0.04] leading-none select-none">"</div>
              <div class="flex items-center gap-1 mb-5 flex-shrink-0">
                {[1,2,3,4,5].map(() => <span class="material-symbols-rounded text-yellow-400 text-lg">star</span>)}
              </div>
              <p class="text-gray-500 text-sm leading-relaxed mb-8 flex-1 relative z-10">{t.quote}</p>
              <div class="flex items-center gap-4 flex-shrink-0 mt-auto">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-red to-navy flex items-center justify-center text-white font-bold text-sm shadow-lg">{t.initials}</div>
                <div>
                  <div class="font-bold text-dark text-sm">{t.name}</div>
                  <div class="text-gray-300 text-xs font-medium">Student</div>
                </div>
              </div>
            </div>
          ))}
        </div>
        <!-- Mobile carousel dots -->
        <div class="flex md:hidden justify-center gap-1 mt-6">
          <button class="testimonial-dot w-10 h-10 flex items-center justify-center" data-index="0" aria-label="Testimonial 1"><span class="block w-2.5 h-2.5 rounded-full bg-navy transition-all"></span></button>
          <button class="testimonial-dot w-10 h-10 flex items-center justify-center" data-index="1" aria-label="Testimonial 2"><span class="block w-2.5 h-2.5 rounded-full bg-navy/30 transition-all"></span></button>
          <button class="testimonial-dot w-10 h-10 flex items-center justify-center" data-index="2" aria-label="Testimonial 3"><span class="block w-2.5 h-2.5 rounded-full bg-navy/30 transition-all"></span></button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="py-24 relative overflow-hidden noise-overlay">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-darker via-navy-dark to-dark"></div>
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-red/15 rounded-full blur-[150px] animate-orb"></div>
      <div class="absolute bottom-[-20%] right-[-10%] w-[500px] h-[500px] bg-indigo/15 rounded-full blur-[150px] animate-orb-reverse"></div>
    </div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10 reveal">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
        Enhance Your Skills
        <span class="block gradient-text-light mt-2">With Best Courses</span>
      </h2>
      <p class="text-white/40 text-lg max-w-2xl mx-auto mb-10">
        Join <span class="text-white/70 font-medium">7,123+</span> students who have transformed their careers at Vista Educare.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="px-10 py-4 bg-white text-navy font-bold rounded-2xl hover:bg-gray-50 transition-all text-lg shadow-2xl shadow-black/20 inline-flex items-center justify-center gap-2">
          Enroll Now <span class="material-symbols-rounded">arrow_forward</span>
        </a>
        <a href="/franchise" class="px-10 py-4 bg-white/[0.06] border border-white/12 text-white font-semibold rounded-2xl hover:bg-white/12 transition-all text-lg">Own a Franchise</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ HOME GALLERY LIGHTBOX ═══════════ -->
  <div id="home-lightbox" class="fixed inset-0 z-[100] bg-dark/95 backdrop-blur-xl opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center p-4 sm:p-8">
    <button id="home-lightbox-close" class="absolute top-6 right-6 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-colors z-10" aria-label="Close lightbox">
      <span class="material-symbols-rounded">close</span>
    </button>
    <!-- Prev / Next arrows -->
    <button id="home-lb-prev" class="absolute left-4 sm:left-8 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-all z-10" aria-label="Previous image">
      <span class="material-symbols-rounded">chevron_left</span>
    </button>
    <button id="home-lb-next" class="absolute right-4 sm:right-8 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center transition-all z-10" aria-label="Next image">
      <span class="material-symbols-rounded">chevron_right</span>
    </button>
    <div class="relative max-w-5xl w-full max-h-full flex items-center justify-center" id="home-lb-content">
      <img id="home-lightbox-img" src="" alt="Gallery view" class="max-w-full max-h-[85vh] object-contain rounded-xl shadow-2xl scale-95 transition-transform duration-300" />
    </div>
  </div>

</MainLayout>

<script>
  // ─── Hero Slider ───
  const track = document.getElementById('sliderTrack');
  const dots = document.querySelectorAll('.slider-dot');
  const prevBtn = document.getElementById('prevSlide');
  const nextBtn = document.getElementById('nextSlide');
  let current = 0;
  const total = 3;
  let interval: ReturnType<typeof setInterval>;

  function goToSlide(n: number) {
    current = ((n % total) + total) % total;
    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  function startAutoplay() {
    interval = setInterval(() => goToSlide(current + 1), 5000);
  }

  dots.forEach(d => d.addEventListener('click', () => {
    clearInterval(interval);
    goToSlide(Number(d.getAttribute('data-slide')));
    startAutoplay();
  }));

  prevBtn?.addEventListener('click', () => { clearInterval(interval); goToSlide(current - 1); startAutoplay(); });
  nextBtn?.addEventListener('click', () => { clearInterval(interval); goToSlide(current + 1); startAutoplay(); });

  startAutoplay();

  // ─── Testimonial Carousel (mobile) ───
  function setupCarousel(trackId: string, dotClass: string) {
    const track = document.getElementById(trackId);
    const dots = document.querySelectorAll(dotClass);

    if (track && dots.length) {
      track.addEventListener('scroll', () => {
        const scrollLeft = track.scrollLeft;
        const cardWidth = track.children[0]?.clientWidth || 1;
        const activeIndex = Math.round(scrollLeft / (cardWidth + 32)); // 32 = gap-8
        dots.forEach((dot, i) => {
          const span = dot.querySelector('span') || dot;
          if (i === activeIndex) {
            span.classList.remove('bg-navy/30');
            span.classList.add('bg-navy');
          } else {
            span.classList.remove('bg-navy');
            span.classList.add('bg-navy/30');
          }
        });
      });

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const idx = Number(dot.getAttribute('data-index'));
          const card = track.children[idx] as HTMLElement;
          if (card) {
            track.scrollTo({ left: card.offsetLeft - 16, behavior: 'smooth' });
          }
        });
      });
    }
  }

  setupCarousel('testimonialTrack', '.testimonial-dot');
  setupCarousel('coursesTrack', '.course-dot');

  // ─── Home Gallery Lightbox ───
  const homeLightbox = document.getElementById('home-lightbox');
  const homeLightboxImg = document.getElementById('home-lightbox-img') as HTMLImageElement;
  const homeLightboxClose = document.getElementById('home-lightbox-close');
  const homeLbPrev = document.getElementById('home-lb-prev');
  const homeLbNext = document.getElementById('home-lb-next');
  const homeLbContent = document.getElementById('home-lb-content');

  // Build unique gallery sources (first half only, skip duplicates)
  const allGalleryItems = Array.from(document.querySelectorAll('[data-gallery-src]'));
  const uniqueSrcs: string[] = [];
  const seen = new Set<string>();
  allGalleryItems.forEach(item => {
    const src = item.getAttribute('data-gallery-src')!;
    if (!seen.has(src)) { seen.add(src); uniqueSrcs.push(src); }
  });

  let currentLbIndex = 0;

  function showLightboxImage(index: number) {
    currentLbIndex = ((index % uniqueSrcs.length) + uniqueSrcs.length) % uniqueSrcs.length;
    if (homeLightboxImg) homeLightboxImg.src = uniqueSrcs[currentLbIndex];
  }

  function openHomeLightbox(src: string) {
    if (homeLightbox && homeLightboxImg) {
      // Find index
      const idx = uniqueSrcs.indexOf(src);
      currentLbIndex = idx >= 0 ? idx : 0;
      homeLightboxImg.src = uniqueSrcs[currentLbIndex];
      homeLightbox.classList.remove('opacity-0', 'pointer-events-none');
      homeLightbox.classList.add('opacity-100', 'pointer-events-auto');
      setTimeout(() => {
        homeLightboxImg.classList.remove('scale-95');
        homeLightboxImg.classList.add('scale-100');
      }, 50);
      document.body.style.overflow = 'hidden';
    }
  }

  function closeHomeLightbox() {
    if (homeLightbox && homeLightboxImg) {
      homeLightbox.classList.remove('opacity-100', 'pointer-events-auto');
      homeLightbox.classList.add('opacity-0', 'pointer-events-none');
      homeLightboxImg.classList.remove('scale-100');
      homeLightboxImg.classList.add('scale-95');
      document.body.style.overflow = '';
      setTimeout(() => { homeLightboxImg.src = ''; }, 300);
    }
  }

  // Attach click to gallery slider items
  allGalleryItems.forEach(item => {
    item.addEventListener('click', () => {
      const src = item.getAttribute('data-gallery-src');
      if (src) openHomeLightbox(src);
    });
  });

  // Arrow buttons
  homeLbPrev?.addEventListener('click', (e) => { e.stopPropagation(); showLightboxImage(currentLbIndex - 1); });
  homeLbNext?.addEventListener('click', (e) => { e.stopPropagation(); showLightboxImage(currentLbIndex + 1); });

  homeLightboxClose?.addEventListener('click', closeHomeLightbox);
  homeLightbox?.addEventListener('click', (e) => {
    if (e.target === homeLightbox) closeHomeLightbox();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!homeLightbox?.classList.contains('opacity-100')) return;
    if (e.key === 'Escape') closeHomeLightbox();
    if (e.key === 'ArrowLeft') showLightboxImage(currentLbIndex - 1);
    if (e.key === 'ArrowRight') showLightboxImage(currentLbIndex + 1);
  });

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  homeLbContent?.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
  homeLbContent?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) showLightboxImage(currentLbIndex + 1);  // swipe left = next
      else showLightboxImage(currentLbIndex - 1);            // swipe right = prev
    }
  }, { passive: true });
</script>
